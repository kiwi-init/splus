# Splus GitHub App — copy to .env and fill in after registering the app.
APP_ID=
PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
WEBHOOK_SECRET=

# Absolute path to the built Rust engine (cargo build --release).
SPLUS_ENGINE=/abs/path/to/Splus/target/release/splus-engine

LOG_LEVEL=info
PORT=3000
