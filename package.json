{
  "name": "splus",
  "version": "0.3.0",
  "private": true,
  "description": "Splus — the precision-first, local-first code reviewer. A deterministic Rust engine your coding agent (Claude Code, Codex, OpenCode) calls over MCP. Open source, runs entirely on your machine.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "engine:build": "cargo build --release",
    "engine:test": "cargo test",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "build:release": "node scripts/build-release.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
